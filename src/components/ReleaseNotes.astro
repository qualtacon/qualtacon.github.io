---
import { Marked } from 'marked';
import ReleaseToc from './ReleaseToc.astro';
import type { ReleaseSection } from '../lib/parseReleaseNotes';

interface Props {
  title: string;
  subtitle: string;
  backHref: string;
  backLabel: string;
  sections: ReleaseSection[];
  downloadUrl?: string;
  downloadVersion?: string;
}

const { title, subtitle, backHref, backLabel, sections, downloadUrl, downloadVersion } =
  Astro.props;

const marked = new Marked({ gfm: true, breaks: true });
const renderedSections = sections.map((section) => ({
  ...section,
  html: marked.parse(section.body),
}));
---

<section class="release-page">
  <div class="container">
    <a class="back-link" href={backHref}>&larr; {backLabel}</a>

    <header class="release-header">
      <div class="release-header-copy">
        <p class="eyebrow">Release notes</p>
        <h1>{title}</h1>
        <p class="subtitle">{subtitle}</p>
      </div>
      {
        downloadUrl && downloadVersion && (
          <a
            class="btn btn-primary release-download"
            href={downloadUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Download latest ({downloadVersion})
          </a>
        )
      }
    </header>

    <div class="release-layout">
      <ReleaseToc sections={sections} />

      <div class="release-sections">
        {
          renderedSections.map((section, index) => (
            <details
              id={section.anchor}
              class="release-version"
              open={index === 0}
              data-release-version
            >
              <summary>
                <span class="summary-version">{section.version}</span>
                {section.date && <time datetime={section.date}>{section.date}</time>}
              </summary>
              <div class="prose release-content" set:html={section.html} />
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const releaseVersions = document.querySelectorAll('[data-release-version]');
  const releaseLinks = document.querySelectorAll('[data-release-link]');

  function openRelease(anchor: string, scroll = true) {
    const section = document.getElementById(anchor);
    if (!(section instanceof HTMLDetailsElement)) return;

    section.open = true;

    if (scroll) {
      section.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    releaseLinks.forEach((link) => {
      link.classList.toggle('is-active', link.getAttribute('data-release-link') === anchor);
    });
  }

  releaseLinks.forEach((link) => {
    link.addEventListener('click', (event) => {
      event.preventDefault();
      const anchor = link.getAttribute('data-release-link');
      if (!anchor) return;
      openRelease(anchor);
      history.replaceState(null, '', `#${anchor}`);
    });
  });

  const initialAnchor = window.location.hash.replace('#', '');
  if (initialAnchor) {
    openRelease(initialAnchor, false);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

      if (!visible?.target.id) return;

      releaseLinks.forEach((link) => {
        link.classList.toggle(
          'is-active',
          link.getAttribute('data-release-link') === visible.target.id
        );
      });
    },
    {
      rootMargin: '-30% 0px -55% 0px',
      threshold: [0, 0.25, 0.5],
    }
  );

  releaseVersions.forEach((section) => observer.observe(section));
</script>

<style>
  .release-page {
    padding: calc(var(--nav-height) + 2.5rem) 0 4rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.92rem;
    font-weight: 500;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .release-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .release-header-copy {
    flex: 1;
    min-width: 0;
  }

  .release-download {
    flex-shrink: 0;
    white-space: nowrap;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--color-accent-hover);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 400;
    color: #fff;
  }

  .subtitle {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .release-layout {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .release-sections {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .release-version {
    scroll-margin-top: calc(var(--nav-height) + 1rem);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .release-version[open] {
    border-color: color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
  }

  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    background: var(--color-surface-elevated);
    user-select: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: '';
    width: 0.55rem;
    height: 0.55rem;
    border-right: 2px solid var(--color-text-muted);
    border-bottom: 2px solid var(--color-text-muted);
    transform: rotate(45deg);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .release-version[open] summary::after {
    transform: rotate(-135deg);
  }

  .summary-version {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-accent-hover);
  }

  summary time {
    margin-right: auto;
    margin-left: 1rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .release-content {
    padding: 1.5rem 1.75rem 1.75rem;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .release-header {
      flex-direction: column;
      align-items: stretch;
    }

    .release-download {
      width: 100%;
    }
  }

  @media (max-width: 1024px) {
    .release-layout {
      grid-template-columns: 1fr;
    }

    summary {
      flex-wrap: wrap;
    }

    summary time {
      margin-left: 0;
      width: 100%;
      order: 3;
    }
  }
</style>