---
import { Marked } from 'marked';
import type { Product } from '../data/products';
import ReleaseToc from './ReleaseToc.astro';
import type { ReleaseSection } from '../lib/parseReleaseNotes';

interface Props {
  product: Product;
  backHref: string;
  backLabel: string;
  sections: ReleaseSection[];
}

const { product, backHref, backLabel, sections } = Astro.props;

const marked = new Marked({ gfm: true, breaks: true });
const renderedSections = sections.map((section) => ({
  ...section,
  html: marked.parse(section.body),
}));
---

<section class="release-page">
  <div class="container">
    <a class="back-link" href={backHref}>&larr; {backLabel}</a>

    <header class="product-hero" style={`--accent: ${product.accent}`}>
      <div class="product-hero-logo">
        <img src={product.image} alt="" loading="lazy" />
      </div>

      <div class="product-hero-copy">
        <div class="product-title-row">
          <h1>{product.name}</h1>
          {product.id === 'v4' && <span class="product-badge">Latest</span>}
        </div>
        <p class="product-version">
          Version {product.version}
          <span class="date">({product.date})</span>
        </p>
      </div>

      <a
        class="btn btn-primary product-download"
        href={product.downloadUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Download
      </a>
    </header>

    <div class="release-layout">
        <ReleaseToc sections={sections} />

        <div class="release-sections">
          {
            renderedSections.map((section, index) => (
              <details
                id={section.anchor}
                class="release-version"
                open={index === 0}
                data-release-version
              >
                <summary>
                  <span class="summary-version">{section.version}</span>
                  {section.date && <time datetime={section.date}>{section.date}</time>}
                </summary>
                <div class="prose release-content" set:html={section.html} />
              </details>
            ))
          }
        </div>
    </div>
  </div>
</section>

<script>
  const releaseVersions = document.querySelectorAll('[data-release-version]');
  const releaseLinks = document.querySelectorAll('[data-release-link]');

  function openRelease(anchor: string, scroll = true) {
    const section = document.getElementById(anchor);
    if (!(section instanceof HTMLDetailsElement)) return;

    section.open = true;

    if (scroll) {
      section.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    releaseLinks.forEach((link) => {
      link.classList.toggle('is-active', link.getAttribute('data-release-link') === anchor);
    });
  }

  releaseLinks.forEach((link) => {
    link.addEventListener('click', (event) => {
      event.preventDefault();
      const anchor = link.getAttribute('data-release-link');
      if (!anchor) return;
      openRelease(anchor);
      history.replaceState(null, '', `#${anchor}`);
    });
  });

  const initialAnchor = window.location.hash.replace('#', '');
  if (initialAnchor) {
    openRelease(initialAnchor, false);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

      if (!visible?.target.id) return;

      releaseLinks.forEach((link) => {
        link.classList.toggle(
          'is-active',
          link.getAttribute('data-release-link') === visible.target.id
        );
      });
    },
    {
      rootMargin: '-30% 0px -55% 0px',
      threshold: [0, 0.25, 0.5],
    }
  );

  releaseVersions.forEach((section) => observer.observe(section));
</script>

<style>
  .release-page {
    padding: calc(var(--nav-height) + 2.5rem) 0 4rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.92rem;
    font-weight: 500;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .product-hero {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 1rem 1.25rem;
    align-items: center;
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .product-hero-logo {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: #11151d;
  }

  .product-hero-logo img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .product-title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem 0.65rem;
  }

  .product-badge {
    padding: 0.2rem 0.5rem;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: 999px;
    background: var(--color-accent-soft);
    color: var(--color-accent-hover);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-hero h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.5vw, 1.85rem);
    font-weight: 400;
    color: #fff;
  }

  .product-version {
    margin: 0.2rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.86rem;
    font-weight: 500;
  }

  .date {
    color: var(--color-text-muted);
  }

  .product-download {
    flex-shrink: 0;
    padding: 0.7rem 1.15rem;
    font-size: 0.84rem;
  }

  .release-layout {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .release-sections {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .release-version {
    scroll-margin-top: calc(var(--nav-height) + 1rem);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .release-version[open] {
    border-color: color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
  }

  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    background: var(--color-surface-elevated);
    user-select: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: '';
    width: 0.55rem;
    height: 0.55rem;
    border-right: 2px solid var(--color-text-muted);
    border-bottom: 2px solid var(--color-text-muted);
    transform: rotate(45deg);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .release-version[open] summary::after {
    transform: rotate(-135deg);
  }

  .summary-version {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-accent-hover);
  }

  summary time {
    margin-right: auto;
    margin-left: 1rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .release-content {
    padding: 1.5rem 1.75rem 1.75rem;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 900px) {
    .product-hero {
      grid-template-columns: auto 1fr;
    }

    .product-download {
      grid-column: 1 / -1;
      width: 100%;
    }
  }

  @media (max-width: 1024px) {
    .release-layout {
      grid-template-columns: 1fr;
    }

    summary {
      flex-wrap: wrap;
    }

    summary time {
      margin-left: 0;
      width: 100%;
      order: 3;
    }
  }

  @media (max-width: 640px) {
    .product-hero {
      grid-template-columns: auto 1fr;
    }

    .product-download {
      grid-column: 1 / -1;
    }
  }
</style>