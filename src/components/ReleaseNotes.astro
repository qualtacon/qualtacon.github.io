---
interface Props {
  title: string;
  subtitle: string;
  backHref: string;
  backLabel: string;
}

const { title, subtitle, backHref, backLabel } = Astro.props;
---

<section class="release-page">
  <div class="container">
    <a class="back-link" href={backHref}>&larr; {backLabel}</a>

    <header class="release-header">
      <p class="eyebrow">Release notes</p>
      <h1>{title}</h1>
      <p class="subtitle">{subtitle}</p>
    </header>

    <article class="prose release-content">
      <slot />
    </article>
  </div>
</section>

<style>
  .release-page {
    padding: calc(var(--nav-height) + 2.5rem) 0 4rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.92rem;
    font-weight: 500;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .release-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--color-accent-hover);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 400;
    color: #fff;
  }

  .subtitle {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .release-content {
    max-width: 820px;
    padding: 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
</style>