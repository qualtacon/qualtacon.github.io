---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <strong>Qualta Consulting</strong>
      <p>Information visualization and advanced data analysis.</p>
    </div>
    <p class="copyright">&copy; {year} Qualta Consulting. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    padding: 2.5rem 0;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-brand strong {
    display: block;
    color: var(--color-text);
    margin-bottom: 0.2rem;
  }

  .footer-brand p,
  .copyright {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .site-footer {
      margin-top: 2rem;
    }
  }
</style>