---
import type { Product } from '../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<article class="product-card" style={`--accent: ${product.accent}`}>
  <div class="product-visual product-visual--logo">
    {product.id === 'v4' && <span class="product-badge">Latest</span>}
    <img src={product.image} alt="" loading="lazy" />
    <div class="product-visual-overlay"></div>
  </div>

  <div class="product-body">
    <div class="product-copy">
      <div class="product-meta">
        <h2>{product.name}</h2>
        <p class="version">
          Version {product.version}
          <span class="date">({product.date})</span>
        </p>
      </div>

      <p class="description">{product.description}</p>
    </div>

    <div class="product-actions">
      <a class="btn btn-primary product-download" href={product.downloadUrl} target="_blank" rel="noopener noreferrer">
        Download
      </a>
      <a class="product-release-link" href={product.releaseNotesPath}>
        Release notes &rarr;
      </a>
    </div>
  </div>
</article>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .product-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
  }

  .product-visual {
    position: relative;
    height: 280px;
    background: var(--color-surface-elevated);
    overflow: hidden;
  }

  .product-visual img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-visual--logo {
    background: #11151d;
  }

  .product-visual--logo img {
    object-fit: contain;
    padding: 2.5rem;
  }

  .product-visual-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 30%,
      rgba(11, 13, 18, 0.55) 100%
    );
    pointer-events: none;
  }

  .product-visual--logo .product-visual-overlay {
    background: linear-gradient(
      180deg,
      transparent 55%,
      rgba(11, 13, 18, 0.35) 100%
    );
  }

  .product-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: space-between;
    padding: 2rem;
  }

  .product-badge {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    z-index: 1;
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(11, 13, 18, 0.72);
    backdrop-filter: blur(8px);
    color: var(--color-accent-hover);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
  }

  .product-meta h2 {
    margin: 0 0 0.35rem;
    font-size: 1.5rem;
    color: #fff;
  }

  .version {
    margin: 0 0 1.25rem;
    color: var(--accent);
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .date {
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .description {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .product-copy {
    flex: 1;
  }

  .product-actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    margin-top: auto;
    padding-top: 1.75rem;
  }

  .product-download {
    display: flex;
    width: 100%;
  }

  .product-release-link {
    margin-top: 1.35rem;
    padding-top: 1.15rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }

  .product-release-link:hover {
    color: var(--color-accent-hover);
  }

  @media (max-width: 768px) {
    .product-visual {
      height: 220px;
    }

    .product-body {
      padding: 1.75rem;
    }
  }
</style>