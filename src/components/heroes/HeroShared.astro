<style is:global>
  .hero-variant {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding: calc(var(--nav-height) + 3rem) 0 4rem;
    overflow: hidden;
  }

  .hero-variant .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #0b0d12 0%, #0f1420 50%, #0b0d12 100%);
  }

  .hero-scroll-cue {
