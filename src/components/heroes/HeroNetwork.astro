---
import HeroContent from '../HeroContent.astro';
import HeroShared from './HeroShared.astro';

const nodes = [
  { id: 1, x: 360, y: 88, r: 7 },
  { id: 2, x: 448, y: 158, r: 9 },
  { id: 3, x: 272, y: 148, r: 6 },
  { id: 4, x: 392, y: 236, r: 8 },
  { id: 5, x: 288, y: 292, r: 7 },
  { id: 6, x: 468, y: 318, r: 6 },
  { id: 7, x: 352, y: 392, r: 8 },
  { id: 8, x: 208, y: 228, r: 5 },
  { id: 9, x: 176, y: 348, r: 6 },
  { id: 10, x: 520, y: 120, r: 7 },
  { id: 11, x: 540, y: 260, r: 8 },
  { id: 12, x: 500, y: 420, r: 6 },
  { id: 13, x: 120, y: 100, r: 5 },
  { id: 14, x: 80, y: 280, r: 6 },
];

const edges = [
  [1, 2],
  [1, 3],
  [1, 4],
  [1, 10],
  [2, 4],
  [2, 6],
  [2, 10],
  [2, 11],
  [3, 4],
  [3, 5],
  [3, 8],
  [3, 13],
  [4, 5],
  [4, 6],
  [4, 7],
  [4, 11],
  [5, 7],
  [5, 8],
  [6, 7],
  [6, 11],
  [6, 12],
  [7, 9],
  [7, 12],
  [8, 5],
  [8, 9],
  [8, 14],
  [9, 14],
  [10, 11],
  [11, 12],
  [13, 8],
];

const nodeById = Object.fromEntries(nodes.map((node) => [node.id, node]));
---

<HeroShared />
<section class="hero-variant hero-network" data-hero-network>
  <div class="hero-bg" aria-hidden="true">
    <svg class="network-graph" viewBox="0 0 600 520" preserveAspectRatio="xMidYMid slice">
      <defs>
        <linearGradient id="edge-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop class="edge-gradient-stop" offset="0%" stop-color="rgba(91, 141, 239, 0.04)" />
          <stop class="edge-gradient-stop edge-gradient-stop--mid" offset="50%" stop-color="rgba(91, 141, 239, 0.16)" />
          <stop class="edge-gradient-stop" offset="100%" stop-color="rgba(91, 141, 239, 0.04)" />
        </linearGradient>
        <radialGradient id="node-gradient">
          <stop class="node-gradient-stop" offset="0%" stop-color="rgba(142, 180, 255, 0.32)" />
          <stop class="node-gradient-stop" offset="100%" stop-color="rgba(62, 106, 225, 0.18)" />
        </radialGradient>
        <filter id="node-glow" x="-100%" y="-100%" width="300%" height="300%">
          <feGaussianBlur stdDeviation="2" result="blur" />
          <feMerge>
            <feMergeNode in="blur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>

      <g class="edges">
        {
          edges.map(([from, to]) => {
            const a = nodeById[from];
            const b = nodeById[to];
            return (
              <line
                x1={a.x}
                y1={a.y}
                x2={b.x}
                y2={b.y}
                stroke="url(#edge-gradient)"
                stroke-width="1.25"
              />
            );
          })
        }
      </g>

      <g class="nodes" filter="url(#node-glow)">
        {
          nodes.map((node) => (
            <>
              <circle
                cx={node.x}
                cy={node.y}
                r={node.r + 4}
                fill="none"
                stroke="rgba(91, 141, 239, 0.06)"
                stroke-width="1"
              />
              <circle
                cx={node.x}
                cy={node.y}
                r={node.r}
                fill="url(#node-gradient)"
              />
            </>
          ))
        }
      </g>
    </svg>
  </div>
  <HeroContent />
  <a href="#products" class="hero-scroll-cue">
    <span class="hero-scroll-label">Explore Vorteks</span>
    <span class="hero-scroll-icon" aria-hidden="true"></span>
  </a>
</section>

<script>
  const hero = document.querySelector('[data-hero-network]');

  if (hero) {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let ticking = false;

    const updateScrollProgress = () => {
      const progress = Math.min(Math.max(window.scrollY / hero.offsetHeight, 0), 1);
      hero.style.setProperty('--scroll-progress', progress.toFixed(4));
      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(updateScrollProgress);
      }
    };

    updateScrollProgress();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', updateScrollProgress);

    if (reducedMotion) {
      hero.classList.add('is-reduced-motion');
    }
  }
</script>

<style>
  .hero-network {
    --scroll-progress: 0;
  }

  .hero-network .hero-scroll-cue {
    opacity: calc(1 - var(--scroll-progress) * 2.5);
    transform: translateX(-50%) translateY(calc(var(--scroll-progress) * -12px));
    transition: opacity 0.15s ease;
  }

  .hero-network .hero-content {
    transform: translateY(calc(var(--scroll-progress) * -28px));
    opacity: calc(1 - var(--scroll-progress) * 0.35);
  }

  .hero-network.is-reduced-motion .hero-content,
  .hero-network.is-reduced-motion .network-graph {
    transform: none;
    filter: none;
  }

  .hero-network.is-reduced-motion .hero-content {
    opacity: calc(1 - var(--scroll-progress) * 0.4);
  }

  .hero-network.is-reduced-motion .network-graph {
    opacity: calc(1 - var(--scroll-progress) * 0.5);
  }
  .hero-network .hero-bg {
    background:
      radial-gradient(ellipse 90% 80% at 10% 40%, rgba(62, 106, 225, 0.14), transparent 55%),
      radial-gradient(ellipse 70% 60% at 85% 60%, rgba(91, 141, 239, 0.1), transparent 50%),
      linear-gradient(160deg, #0b0d12 0%, #101620 45%, #0d1119 100%);
  }

  .network-graph {
    position: absolute;
    top: 50%;
    right: -14%;
    width: 115%;
    height: 130%;
    min-width: 900px;
    overflow: visible;
    transform:
      translateY(calc(-50% - var(--scroll-progress) * 140px))
      translateX(calc(var(--scroll-progress) * 48px))
      scale(calc(1 + var(--scroll-progress) * 0.2))
      rotate(calc(var(--scroll-progress) * 5deg));
    opacity: calc(1 - var(--scroll-progress) * 0.8);
    filter: blur(calc(var(--scroll-progress) * 4px));
    will-change: transform, opacity, filter;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      transparent calc(42% + var(--scroll-progress) * 18%),
      rgba(0, 0, 0, 0.2) calc(58% + var(--scroll-progress) * 12%),
      rgba(0, 0, 0, 0.45) calc(72% + var(--scroll-progress) * 8%),
      black calc(88% + var(--scroll-progress) * 12%)
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      transparent calc(42% + var(--scroll-progress) * 18%),
      rgba(0, 0, 0, 0.2) calc(58% + var(--scroll-progress) * 12%),
      rgba(0, 0, 0, 0.45) calc(72% + var(--scroll-progress) * 8%),
      black calc(88% + var(--scroll-progress) * 12%)
    );
  }

  .edges line {
    stroke-linecap: round;
  }

  .network-graph .edge-gradient-stop--mid {
    stop-color: color-mix(
      in srgb,
      rgba(130, 172, 255, 0.34) calc(var(--scroll-progress) * 100%),
      rgba(91, 141, 239, 0.16) calc((1 - var(--scroll-progress)) * 100%)
    );
  }

  .network-graph .node-gradient-stop:first-child {
    stop-color: color-mix(
      in srgb,
      rgba(176, 206, 255, 0.52) calc(var(--scroll-progress) * 100%),
      rgba(142, 180, 255, 0.32) calc((1 - var(--scroll-progress)) * 100%)
    );
  }

  .network-graph .nodes {
    opacity: calc(1 - var(--scroll-progress) * 0.25);
  }

  @media (max-width: 768px) {
    .network-graph {
      min-width: 0;
    }
  }
</style>