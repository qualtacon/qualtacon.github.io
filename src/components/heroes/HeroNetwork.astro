---
import HeroContent from '../HeroContent.astro';
import HeroShared from './HeroShared.astro';

const nodes = [
  { id: 1, x: 360, y: 88, r: 7 },
  { id: 2, x: 448, y: 158, r: 9 },
  { id: 3, x: 272, y: 148, r: 6 },
  { id: 4, x: 392, y: 236, r: 8 },
  { id: 5, x: 288, y: 292, r: 7 },
  { id: 6, x: 468, y: 318, r: 6 },
  { id: 7, x: 352, y: 392, r: 8 },
  { id: 8, x: 208, y: 228, r: 5 },
  { id: 9, x: 176, y: 348, r: 6 },
  { id: 10, x: 520, y: 120, r: 7 },
  { id: 11, x: 540, y: 260, r: 8 },
  { id: 12, x: 500, y: 420, r: 6 },
  { id: 13, x: 120, y: 100, r: 5 },
  { id: 14, x: 80, y: 280, r: 6 },
];

const edges = [
  [1, 2],
  [1, 3],
  [1, 4],
  [1, 10],
  [2, 4],
  [2, 6],
  [2, 10],
  [2, 11],
  [3, 4],
  [3, 5],
  [3, 8],
  [3, 13],
  [4, 5],
  [4, 6],
  [4, 7],
  [4, 11],
  [5, 7],
  [5, 8],
  [6, 7],
  [6, 11],
  [6, 12],
  [7, 9],
  [7, 12],
  [8, 5],
  [8, 9],
  [8, 14],
  [9, 14],
  [10, 11],
  [11, 12],
  [13, 8],
];

const nodeById = Object.fromEntries(nodes.map((node) => [node.id, node]));
---

<HeroShared />
<section class="hero-variant hero-network">
  <div class="hero-bg" aria-hidden="true">
    <svg class="network-graph" viewBox="0 0 600 520" preserveAspectRatio="xMidYMid slice">
      <defs>
        <linearGradient id="edge-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="rgba(91, 141, 239, 0.04)" />
          <stop offset="50%" stop-color="rgba(91, 141, 239, 0.16)" />
          <stop offset="100%" stop-color="rgba(91, 141, 239, 0.04)" />
        </linearGradient>
        <radialGradient id="node-gradient">
          <stop offset="0%" stop-color="rgba(142, 180, 255, 0.32)" />
          <stop offset="100%" stop-color="rgba(62, 106, 225, 0.18)" />
        </radialGradient>
        <filter id="node-glow" x="-100%" y="-100%" width="300%" height="300%">
          <feGaussianBlur stdDeviation="2" result="blur" />
          <feMerge>
            <feMergeNode in="blur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>

      <g class="edges">
        {
          edges.map(([from, to]) => {
            const a = nodeById[from];
            const b = nodeById[to];
            return (
              <line
                x1={a.x}
                y1={a.y}
                x2={b.x}
                y2={b.y}
                stroke="url(#edge-gradient)"
                stroke-width="1.25"
              />
            );
          })
        }
      </g>

      <g class="nodes" filter="url(#node-glow)">
        {
          nodes.map((node) => (
            <>
              <circle
                cx={node.x}
                cy={node.y}
                r={node.r + 4}
                fill="none"
                stroke="rgba(91, 141, 239, 0.06)"
                stroke-width="1"
              />
              <circle
                cx={node.x}
                cy={node.y}
                r={node.r}
                fill="url(#node-gradient)"
              />
            </>
          ))
        }
      </g>
    </svg>
  </div>
  <HeroContent />
  <a href="#products" class="hero-scroll-cue">
    <span class="hero-scroll-label">Explore Vorteks</span>
    <span class="hero-scroll-icon" aria-hidden="true"></span>
  </a>
</section>

<style>
  .hero-network .hero-bg {
    background:
      radial-gradient(ellipse 90% 80% at 10% 40%, rgba(62, 106, 225, 0.14), transparent 55%),
      radial-gradient(ellipse 70% 60% at 85% 60%, rgba(91, 141, 239, 0.1), transparent 50%),
      linear-gradient(160deg, #0b0d12 0%, #101620 45%, #0d1119 100%);
  }

  .network-graph {
    --network-opacity: 1;
    position: absolute;
    top: 50%;
    right: -14%;
    width: 115%;
    height: 130%;
    min-width: 900px;
    transform: translateY(-50%);
    opacity: var(--network-opacity);
    overflow: visible;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      transparent 42%,
      rgba(0, 0, 0, 0.2) 58%,
      rgba(0, 0, 0, 0.45) 72%,
      black 88%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      transparent 42%,
      rgba(0, 0, 0, 0.2) 58%,
      rgba(0, 0, 0, 0.45) 72%,
      black 88%
    );
  }

  .edges line {
    stroke-linecap: round;
  }

  @media (max-width: 768px) {
    .network-graph {
      min-width: 0;
    }
  }
</style>