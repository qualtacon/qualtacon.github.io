---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReleaseNotes from '../../components/ReleaseNotes.astro';
import v4Notes from '../../content/releases/vorteks-4.md?raw';
import { products } from '../../data/products';
import { parseReleaseNotes } from '../../lib/parseReleaseNotes';

const sections = parseReleaseNotes(v4Notes);
const product = products.find((entry) => entry.id === 'v4')!;
---

<BaseLayout
  title="Vorteks 4 Release Notes"
  description="Release notes and changelog for Vorteks 4."
>
  <ReleaseNotes
    title="Vorteks 4"
    subtitle="Complete changelog for the next-generation all-in-one Vorteks application."
    backHref="/"
    backLabel="Back to home"
    sections={sections}
    downloadUrl={product.downloadUrl}
    downloadVersion={product.version}
  />
</BaseLayout>