---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReleaseNotes from '../../components/ReleaseNotes.astro';
import v3Notes from '../../content/releases/vorteks-3.md?raw';
import { products } from '../../data/products';
import { parseReleaseNotes } from '../../lib/parseReleaseNotes';

const sections = parseReleaseNotes(v3Notes);
const product = products.find((entry) => entry.id === 'v3')!;
---

<BaseLayout
  title="Vorteks 3"
  description="Download Vorteks 3 and browse release notes for the processing, storage, and visualization suite."
>
  <ReleaseNotes
    product={product}
    backHref="/"
    backLabel="Back to home"
    sections={sections}
  />
</BaseLayout>