---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReleaseNotes from '../../components/ReleaseNotes.astro';
import v3Notes from '../../content/releases/vorteks-3.md?raw';
import { products } from '../../data/products';
import { parseReleaseNotes } from '../../lib/parseReleaseNotes';

const sections = parseReleaseNotes(v3Notes);
const product = products.find((entry) => entry.id === 'v3')!;
---

<BaseLayout
  title="Vorteks 3 Release Notes"
  description="Release notes and changelog for Vorteks 3."
>
  <ReleaseNotes
    title="Vorteks 3"
    subtitle="Complete changelog for the Vorteks 3 processing, storage, and visualization suite."
    backHref="/"
    backLabel="Back to home"
    sections={sections}
    downloadUrl={product.downloadUrl}
    downloadVersion={product.version}
  />
</BaseLayout>