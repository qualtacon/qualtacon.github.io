---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroNetwork from '../components/heroes/HeroNetwork.astro';
import HeroFlow from '../components/heroes/HeroFlow.astro';
import HeroBars from '../components/heroes/HeroBars.astro';
import HeroRings from '../components/heroes/HeroRings.astro';
import HeroMesh from '../components/heroes/HeroMesh.astro';

const examples = [
  { id: 'network', label: 'Network graph', description: 'Node-link visualization — closest to Vorteks network views.', component: HeroNetwork },
  { id: 'flow', label: 'Data streams', description: 'Flowing lines and pulses — timeline / stream graph feel.', component: HeroFlow },
  { id: 'bars', label: 'Analytics bars', description: 'Abstract bar chart — classic BI and dashboard vibe.', component: HeroBars },
  { id: 'rings', label: 'Correlation rings', description: 'Concentric rings — geographic / correlation analysis feel.', component: HeroRings },
  { id: 'mesh', label: 'Gradient mesh', description: 'Soft blobs — minimal, modern, least literal.', component: HeroMesh },
];
---

<BaseLayout title="Hero Examples" description="CSS-only hero background options for Qualta Consulting.">
  <div class="examples-intro">
    <div class="container">
      <p class="eyebrow">Preview only</p>
      <h1>CSS hero examples</h1>
      <p>Scroll to compare styles. The homepage still uses <strong>Network graph</strong> until you pick one.</p>
      <a class="btn btn-secondary" href="/">Back to homepage</a>
    </div>
  </div>

  {
    examples.map((example) => {
      const HeroExample = example.component;
      return (
        <div class="example-block" id={example.id}>
          <div class="example-label container">
            <h2>{example.label}</h2>
            <p>{example.description}</p>
          </div>
          <HeroExample />
        </div>
      );
    })
  }
</BaseLayout>

<style>
  .examples-intro {
    padding: calc(var(--nav-height) + 2rem) 0 2rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .examples-intro h1 {
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 400;
    color: #fff;
  }

  .examples-intro p {
    margin: 0 0 1.25rem;
    color: var(--color-text-muted);
    max-width: 52ch;
  }

  .examples-intro .eyebrow {
    margin: 0 0 0.5rem;
    color: var(--color-accent-hover);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .example-block + .example-block {
    border-top: 4px solid var(--color-border);
  }

  .example-label {
    position: relative;
    z-index: 2;
    padding: 1.25rem 0 0;
  }

  .example-label h2 {
    margin: 0 0 0.25rem;
    font-size: 1.1rem;
    color: var(--color-accent-hover);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .example-label p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.92rem;
  }

  .example-block :global(.hero-variant) {
    min-height: 72vh;
    padding-top: 1rem;
  }
</style>